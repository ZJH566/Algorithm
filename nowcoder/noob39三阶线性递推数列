#斐波那契是二级
#法一数组
n = int(input())
a = [0, 1, 1]
if n > 3:
    for i in range(3, n):
        a.append(a[i-3] + 2*a[i-2] + a[i-1])
print(a[n-1])
#法二滚动变量
n = int(input())
if n == 1:
    print(0)
elif n == 2 or n == 3:
    print(1)
else:
    a, b, c = 0, 1, 1
    for i in range(4, n+1):
        a, b, c = b, c, a+2*b+c
    print(c)